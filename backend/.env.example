# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=project01

# JWT配置
SECRET_KEY=you_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILENAME=app.log

# 跨域配置(多个域名用逗号分隔)
# 示例:
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:5173
CORS_ALLOW_ORIGINS=*

# AI配置(示例占位，后续请替换为真实值)
AI_BASE_URL=https://example-openai-compatible-api/v1
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-4o-mini
